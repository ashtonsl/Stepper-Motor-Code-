#define X_STEP_PIN 2
#define X_DIR_PIN  3

#define Y_STEP_PIN 4
#define Y_DIR_PIN  5

#define Z_STEP_PIN 6
#define Z_DIR_PIN  7

const long PULSES_PER_REV = 40000;
const float SCREW_PITCH_MM = 5.0;
const float PULSES_PER_MM = PULSES_PER_REV / SCREW_PITCH_MM;

const int STEP_DELAY_US = 20;

void moveAxis(int stepPin, int dirPin, float mm);

void setup() {

  pinMode(X_STEP_PIN, OUTPUT);
  pinMode(X_DIR_PIN, OUTPUT);

  pinMode(Y_STEP_PIN, OUTPUT);
  pinMode(Y_DIR_PIN, OUTPUT);

  pinMode(Z_STEP_PIN, OUTPUT);
  pinMode(Z_DIR_PIN, OUTPUT);

  Serial.begin(115200);
}

void loop() {

  float x_mm, y_mm, z_mm;

  Serial.println("Enter X distance in mm:");
  while (Serial.available() == 0) {}
  x_mm = Serial.parseFloat();

  while (Serial.available() > 0) Serial.read();

  Serial.println("Enter Y distance in mm:");
  while (Serial.available() == 0) {}
  y_mm = Serial.parseFloat();

  while (Serial.available() > 0) Serial.read();

  Serial.println("Enter Z distance in mm:");
  while (Serial.available() == 0) {}
  z_mm = Serial.parseFloat();

  while (Serial.available() > 0) Serial.read();

  moveAxis(X_STEP_PIN, X_DIR_PIN, x_mm);
  moveAxis(Y_STEP_PIN, Y_DIR_PIN, y_mm);
  moveAxis(Z_STEP_PIN, Z_DIR_PIN, z_mm);

  Serial.println("Motion complete.\n");

  delay(1000);
}

void moveAxis(int stepPin, int dirPin, float mm) {

  long totalPulses = mm * PULSES_PER_MM;

  digitalWrite(dirPin, HIGH);

  for (long i = 0; i < totalPulses; i++) {
    digitalWrite(stepPin, HIGH);
    delayMicroseconds(STEP_DELAY_US);
    digitalWrite(stepPin, LOW);
    delayMicroseconds(STEP_DELAY_US);
  }
}
